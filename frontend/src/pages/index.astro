---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.tsx';
import Scanner from '../components/Scanner.tsx';
---

<Layout title="Escanear API - API Security Scanner">
	<div class="gradient-dark-bg min-h-screen">
		<Navbar client:load />
		
		<main class="mx-auto max-w-7xl px-6 py-12 relative z-10">
			<!-- Encabezado Principal -->
			<div class="text-center mb-16 fade-in">
				<h2 class="text-4xl md:text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-indigo-400 mb-6 drop-shadow-sm">
					Protege tu API en Segundos
				</h2>
				<p class="text-lg text-slate-400 max-w-2xl mx-auto">
					Detecta vulnerabilidades Críticas (OWASP), Inyecciones SQL, problemas de CORS y más. Analiza tu entorno antes que los atacantes.
				</p>
			</div>

			<Scanner client:load />
		</main>

		<!-- Background Elements -->
		<div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10 pointer-events-none">
			<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-purple-600/20 blur-[120px]"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-indigo-600/20 blur-[120px]"></div>
		</div>
	</div>
</Layout>
